# Database
DATABASE_URL=file:./db/custom.db

# ─── AI Provider 配置 ─────────────────────────────
# 支持的 provider: z-ai | openai | anthropic | custom
AI_PROVIDER=z-ai

# 可选：覆盖默认模型
# AI_MODEL=

# ─── OpenAI / Custom 配置 ────────────────────────
# AI_BASE_URL=https://api.openai.com/v1
# AI_API_KEY=sk-xxx

# ─── Anthropic 配置 ──────────────────────────────
# AI_BASE_URL=https://api.anthropic.com
# AI_API_KEY=sk-ant-xxx
# AI_MODEL=claude-sonnet-4-20250514

# ─── 自定义 (OpenAI-compatible) 配置 ──────────────
# AI_PROVIDER=custom
# AI_BASE_URL=https://your-api.example.com/v1
# AI_API_KEY=your-key
# AI_MODEL=your-model-name

# ─── 可选参数 ────────────────────────────────────
# AI_MAX_TOKENS=4096
# AI_TEMPERATURE=0.7

# ─── z-ai 专用 ───────────────────────────────────
# ZAI_CONFIG_PATH=.z-ai-config
